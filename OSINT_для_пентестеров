sublist3r -d cyberyozh.com -o sublist3r.txt
amass enum -d cyberyozh.com -o amass.txt
cat sublist3r.txt amass.txt | sort -u > subs_all.txt
wc -l subs_all.txt   # сколько уникальных поддоменов

"$(go env GOPATH)"/bin/httpx -l subs_all.txt --ports 80,443 --status-code --title --server --silent -o http_hosts.txt

# robots для одного хоста
curl -fsS https://www.cyberyozh.com/robots.txt || echo "no robots"
https://cyberyozh.com/robots.txt

# заголовки
curl -I https://www.cyberyozh.com

